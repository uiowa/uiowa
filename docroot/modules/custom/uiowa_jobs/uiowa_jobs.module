<?php

/**
 * @file
 * Primary module hooks for uiowa_jobs module.
 */

use Drupal\Core\Cache\Cache;
use Drupal\Core\Form\FormStateInterface;
use Drupal\uiowa_core\HeadlineHelper;

/**
 * Implements hook_form_alter().
 */
function uiowa_jobs_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $validator = 'uiowa_jobs_validate_feed_url';
  // Add validation to the feed URL field on uiowa_jobs block forms.
  if ($form_id === 'layout_builder_add_block' || $form_id === 'layout_builder_update_block') {
    if (isset($form['settings']['block_form']['field_uiowa_jobs_feed_url'])) {
      // Add validation handler.
      $form['settings']['block_form']['field_uiowa_jobs_feed_url']['widget'][0]['value']['#element_validate'][] = $validator;
    }
  }

  // Also handle non-layout-builder forms.
  if (strpos($form_id, 'block_content_uiowa_jobs_') === 0) {
    if (isset($form['field_uiowa_jobs_feed_url'])) {
      $form['field_uiowa_jobs_feed_url']['widget'][0]['value']['#element_validate'][] = $validator;
      $form['field_uiowa_jobs_feed_url']['widget'][0]['value']['#description'] = $help_text;
    }
  }
}

/**
 * Validation callback for feed URL field.
 */
function uiowa_jobs_validate_feed_url($element, FormStateInterface $form_state, $form) {
  $url = $element['#value'];

  if (empty($url)) {
    // Empty is okay if field is not required or has a default.
    return;
  }

  // Use the parser service to validate.
  /** @var \Drupal\uiowa_jobs\RssFeedParser $parser */
  $parser = \Drupal::service('uiowa_jobs.rss_parser');

  if (!$parser->validateFeedUrl($url)) {
    $form_state->setError($element, t('Feed URL must be from hris.uiowa.edu and use the OTAC RSS format (https://hris.uiowa.edu/otac-rss/...).'));
  }
}

/**
 * Implements hook_preprocess_HOOK().
 */
function uiowa_jobs_preprocess_block__inline_block__uiowa_jobs(&$variables) {
  /** @var \Drupal\block_content\BlockContentInterface $block */
  $block = $variables['elements']['content']['#block_content'];

  if (!isset($variables['attributes']['class'])) {
    $variables['attributes']['class'] = [];
  }

  $variables['attributes']['class'][] = 'list-container';

  // Get block configuration.
  $feed_url = $block->get('field_uiowa_jobs_feed_url')->getString();
  $per_page = (int) $block->get('field_uiowa_jobs_count')->getString() ?: 10;
  $show_pager = (bool) $block->get('field_uiowa_jobs_pager')->getString();
  $include_date = (bool) $block->get('field_uiowa_jobs_show_date')->getString();
  $include_description = (bool) $block->get('field_uiowa_jobs_show_desc')->getString();
  $no_results_text = 'No job postings are currently available.';

  if (empty($feed_url)) {
    $variables['content']['no_results'] = [
      '#markup' => '<p>Feed URL is not configured.</p>',
    ];
    return;
  }

  try {
    // Fetch and parse RSS feed.
    /** @var \Drupal\uiowa_jobs\RssFeedParser $parser */
    $parser = \Drupal::service('uiowa_jobs.rss_parser');
    $jobs = $parser->parse($feed_url);

    // Sort by publication date descending (most recent first).
    if (!empty($jobs)) {
      usort($jobs, function ($a, $b) {
        return $b->pubDate <=> $a->pubDate;
      });
    }

    if (empty($jobs)) {
      $variables['content']['no_results'] = [
        '#markup' => $no_results_text,
        '#prefix' => '<div class="uiowa-jobs-no-results">',
        '#suffix' => '</div>',
      ];
      return;
    }

    // Create container for jobs.
    $variables['content']['jobs'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => [
          'jobs-wrapper',
          'uiowa-jobs',
          'list-container__inner',
        ],
      ],
    ];

    // Determine heading size for child items.
    $heading_size = 'h3';
    $headline = $block->get('field_uiowa_headline')
      ?->first()
      ?->getValue();

    // Get the appropriate heading size.
    if (!is_null($headline)) {
      if (empty($headline['headline'])) {
        $heading_size = $headline['child_heading_size'];
      }
      else {
        $heading_size = HeadlineHelper::getHeadingSizeUp($headline['heading_size']);
      }
    }

    // If output is paged, paginate the jobs.
    if ($show_pager) {
      $count = count($jobs);
      static $element = 0;
      $element++;
      /** @var \Drupal\Core\Pager\PagerManager $pager */
      $pager = \Drupal::service('pager.manager');
      $chunks = array_chunk($jobs, $per_page);
      $current = $pager->createPager($count, $per_page, $element)->getCurrentPage();
      $jobs = $chunks[$current] ?? [];
    }
    else {
      // Limit to first N jobs.
      $jobs = array_slice($jobs, 0, $per_page);
    }

    // Build cards for each job.
    $variables['content']['jobs']['items'] = [];
    foreach ($jobs as $index => $job) {
      $override_styles = $variables['elements']['#override_styles'] ?? [];
      $variables['content']['jobs']['items'][$index] = uiowa_jobs_build_job_card(
        $job,
        $heading_size,
        $include_date,
        $include_description,
        $override_styles,
      );
    }

    // Add pager if enabled.
    if ($show_pager) {
      $variables['content']['pager'] = [
        '#type' => 'pager',
        '#element' => $element,
        '#quantity' => 3,
      ];
    }

    // Add cache tags.
    $cache_id = 'uiowa_jobs:feed:' . md5($feed_url);
    $variables['#cache']['tags'] = Cache::mergeTags(
      $variables['#cache']['tags'] ?? [],
      ['uiowa_jobs:feed', $cache_id]
    );
    // Cache for an hour by default.
    $variables['#cache']['max-age'] = 3600;

    // Add cache context for pager.
    if ($show_pager) {
      $variables['#cache']['contexts'][] = 'url.query_args.pagers';
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('uiowa_jobs')->error('Failed to display jobs: @error', [
      '@error' => $e->getMessage(),
    ]);
    $variables['content']['error'] = [
      '#markup' => '<p>Unable to load job postings. Please try again later.</p>',
    ];
  }
}

/**
 * Build a job card render array.
 *
 * @param \stdClass $job
 *   The job object from RSS parser.
 * @param string $heading_size
 *   The heading size for the card title.
 * @param bool $include_date
 *   Whether to include the job posting date.
 * @param bool $include_description
 *   Whether to include the job posting summary.
 * @param array $override_styles
 *   Optional style overrides from layout builder.
 *
 * @return array
 *   Render array for the job card.
 */
function uiowa_jobs_build_job_card(\stdClass $job, string $heading_size = 'h3', bool $include_date = TRUE, bool $include_description = FALSE, array $override_styles = []): array {
  $build = [
    '#type' => 'card',
    '#prefix' => '<div class="column-container">',
    '#suffix' => '</div>',
  ];

  // Attach libraries.
  $build['#attached']['library'][] = 'uids_base/card';

  // Set the title.
  $build['#title'] = html_entity_decode($job->title);
  $build['#title_heading_size'] = $heading_size;

  // Set the URL (links to HRIS).
  $build['#url'] = $job->link;

  // Set subtitle with formatted date and a simple label.
  if ($include_date && !empty($job->pubDate)) {
    $formatted_date = \Drupal::service('date.formatter')->format($job->pubDate, 'medium');
    $build['#subtitle']['posted_date'] = [
      '#markup' => "Posted {$formatted_date}",
    ];
  }

  // Set content with cleaned description.
  if ($include_description && !empty($job->description)) {
    $build['#content'] = [
      '#markup' => $job->description,
    ];
  }

  // Apply card styles.
  $style_map = [
    'card_headline_style' => 'headline--serif',
    'card_media_position' => 'card--layout-right',
    'media_format' => 'media--widescreen',
    'media_size' => 'media--small',
    'border' => 'borderless',
    ...$override_styles,
    'uiowa_jobs_item' => 'uiowa-jobs-item',
  ];

  $build['#attributes']['class'] = array_values($style_map);

  return $build;
}
