{
  "name": "uiowa_site_theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -f css/*.css",
    "sass-compile": "mkdir -p css && sass --no-source-map sass/global.scss css/global.css",
    "sass-watch": "mkdir -p css && sass --watch --no-source-map sass/global.scss css/global.css",
    "prebuild": "run-s clean",
    "build": "run-p sass-compile",
    "watch": "run-p sass-watch"
  },
  "dependencies": {
    "sass": "^1.89.0",
    "npm-run-all": "^4.1.3",
    "uids_base": "^1.0.0"
  }
}
