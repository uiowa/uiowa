#!/usr/bin/env php
<?php

/**
 * @file
 * SiteNow CLI (sn).
 *
 * Standalone Symfony Console entry point for SiteNow repository commands.
 * Commands are hand-wired here; there is no DI container by design. Each
 * command documents where it must run: some touch the git working tree and run
 * on the host shell (e.g. multisite:create), while others need the DDEV
 * container's drush aliases and SSH agent (e.g. the report:* commands, run via
 * `ddev exec ./sn ...`).
 *
 * Run from the repository root, e.g.:
 *   ./sn multisite:create newsite.uiowa.edu --dry-run
 *   ddev exec ./sn report:domains
 */

use SiteNow\Command\DeployActivateCommand;
use SiteNow\Command\DeployDistributeCommand;
use SiteNow\Command\DeployPostDbCopyCommand;
use SiteNow\Command\DeployUpdateCommand;
use SiteNow\Command\DeployVersionStampCommand;
use SiteNow\Command\MultisiteCreateCommand;
use SiteNow\Command\MultisiteExecuteCommand;
use SiteNow\Command\ReportDomainsCommand;
use SiteNow\Command\ReportInactiveCommand;
use SiteNow\Command\ReportSplitsCommand;
use SiteNow\Command\RoutesCustomCommand;
use SiteNow\Command\SiteSyncCommand;
use SiteNow\Command\SiteUpdateCommand;
use SiteNow\Command\SyncAllCommand;
use Symfony\Component\Console\Application;

// This file lives at the repository root.
$root = __DIR__;

require "{$root}/vendor/autoload.php";

// Repo-touching commands assume the working directory is the repository root.
chdir($root);

$application = new Application('sn');
$application->add(new DeployActivateCommand($root));
$application->add(new DeployDistributeCommand($root));
$application->add(new DeployPostDbCopyCommand($root));
$application->add(new DeployUpdateCommand($root));
$application->add(new DeployVersionStampCommand($root));
$application->add(new MultisiteCreateCommand($root));
$application->add(new MultisiteExecuteCommand($root));
$application->add(new ReportDomainsCommand($root));
$application->add(new ReportInactiveCommand($root));
$application->add(new ReportSplitsCommand($root));
$application->add(new RoutesCustomCommand($root));
$application->add(new SiteSyncCommand($root));
$application->add(new SiteUpdateCommand($root));
$application->add(new SyncAllCommand($root));
$application->run();
